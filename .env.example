# =============================================================================
# Kazi — environment template. Copy to .env and fill in. NEVER commit .env.
# Values marked (verify) must be confirmed against live docs before relying on
# them (Build Spec, Ground rule 2). Do not invent addresses.
# =============================================================================

# --- Chain ------------------------------------------------------------------
# Alfajores testnet RPC. (verify current endpoint at docs.celo.org)
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
CHAIN=alfajores
CHAIN_ID=44787

# Deployer + agent wallets (test wallets only — fund from the Celo faucet).
DEPLOYER_PRIVATE_KEY=
AGENT_PRIVATE_KEY=

# --- Stablecoin -------------------------------------------------------------
# Alfajores cUSD. (verify) Celo dev docs list the testnet cUSD address.
CUSD_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# --- ERC-8004 registries (verify live Celo deployments — do NOT guess) ------
ERC8004_IDENTITY_REGISTRY=
ERC8004_REPUTATION_REGISTRY=
ERC8004_VALIDATION_REGISTRY=

# --- x402 / thirdweb --------------------------------------------------------
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
X402_FACILITATOR_URL=          # (verify) testnet facilitator

# --- Self (identity) --------------------------------------------------------
SELF_API_KEY=                  # (verify current SDK / integration)
SELF_APP_ID=
SELF_SCOPE=kazi

# --- Agent policy -----------------------------------------------------------
HARVEST_INTERVAL_SECONDS=300
RESERVE_BPS=1000               # 10% idle withdrawal reserve
STREAM_SHARE_BPS=10000         # MVP: 100% of yield streams to savers
BUFFER_SHARE_BPS=0             # MVP: 0% to junior buffer (pure capital-protected)
MIN_CREDIT_SCORE=600           # conservative
CREDIT_ENABLED=false           # flag-gated credit module (Spec §2)

# --- Servers ----------------------------------------------------------------
AGENT_PORT=8787                # /status, /activity
INSTITUTION_PORT=8788          # x402-priced demo "institution agent" endpoint

# --- Web (Next.js, public) --------------------------------------------------
NEXT_PUBLIC_CHAIN=alfajores
NEXT_PUBLIC_AGENT_URL=http://localhost:8787
