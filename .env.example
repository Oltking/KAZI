# =============================================================================
# Kazi — environment template. Copy to .env and fill in. NEVER commit .env.
# Values marked (verify) must be confirmed against live docs before relying on
# them (Build Spec, Ground rule 2). Do not invent addresses.
# =============================================================================

# --- Chain ------------------------------------------------------------------
# Celo Sepolia is the current Celo testnet (Alfajores is legacy). (verify)
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CHAIN=sepolia               # celo | sepolia | alfajores | local
CHAIN_ID=11142220
# For the local end-to-end (scripts/e2e-local.sh) anvil runs with this chain-id
# so the celoSepolia viem chain matches; set CELO_RPC_URL=http://127.0.0.1:8545.

# Deployer + agent wallets (test wallets only — fund from the Celo Sepolia faucet).
DEPLOYER_PRIVATE_KEY=
AGENT_PRIVATE_KEY=

# --- Stablecoin -------------------------------------------------------------
# Celo Sepolia cUSD. (verify on the explorer before relying on it.)
CUSD_ADDRESS=0x765de816845861e75a25fca122bb6898b8b1282a
USE_REAL_CUSD=false          # E2E/demo deploys a MockUSD so MockStrategy yields work

# --- ERC-8004 registries ----------------------------------------------------
# Addresses below were sourced from the erc-8004/erc-8004-contracts repo
# (vanity 0x8004... deployments). (verify) each on the relevant explorer before
# relying on them — confirm Celo testnet = Celo Sepolia vs Alfajores for your RPC.
#   Celo mainnet:  Identity 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
#                  Reputation 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e   # Celo Sepolia (verify)
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713  # Celo Sepolia (verify)
ERC8004_VALIDATION_REGISTRY=
# Public HTTPS URL where the agent's ERC-8004 registration file is served (the
# agentURI minted on-chain, so 8004scan can resolve the card). The deployed web
# app serves it at <domain>/registration.json — set this to your Vercel URL.
AGENT_PUBLIC_URL=http://localhost:8787

# --- x402 / thirdweb --------------------------------------------------------
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
X402_FACILITATOR_URL=          # (verify) leave empty to use thirdweb's default facilitator
X402_PAY_TO=                   # address the institution agent receives x402 payments at
X402_PRICE=$0.001              # USD price (used when no explicit token is set)
# Explicit payment token — REQUIRED on networks where thirdweb has no default
# USD stablecoin (e.g. Celo Sepolia). Must support EIP-2612 permit / ERC-3009.
# On Celo mainnet, set this to USDC instead and leave name/version blank.
X402_TOKEN=                    # e.g. the PermitUSD test token, or mainnet USDC
X402_TOKEN_DECIMALS=18
X402_AMOUNT=1000000000000000   # price in token base units (0.001 @ 18dp)
X402_TOKEN_NAME=               # EIP-2612 permit domain name (e.g. "Kazi Demo USD")
X402_TOKEN_VERSION=1

# --- Self (identity) — OFF-CHAIN backend verification -----------------------
# The Self app posts the proof to /api/self-verify, which verifies it with
# @selfxyz/core and the agent records the attestation on-chain (Celo Sepolia).
# Works with the normal production Self app; no funds.
SELF_SCOPE_SEED=kazi           # must match NEXT_PUBLIC_SELF_SCOPE_SEED
# The PUBLIC URL of the verify route. The scope is derived from this, so the
# server SELF_ENDPOINT and web NEXT_PUBLIC_SELF_ENDPOINT MUST be identical.
SELF_ENDPOINT=https://kazi-agent.vercel.app/api/self-verify
# false = production Self app + a real document (reads the Celo mainnet hub).
# true  = Self staging/mock app (reads the Celo Sepolia hub).
SELF_MOCK_PASSPORT=false
# On-chain SelfVerifier (only used by the legacy on-chain flow; off-chain ignores it)
SELF_HUB_V2=0x16ECBA51e18a4a7e61fdC417f0d47AFEeDfbed74   # Celo Sepolia (verify)

# --- Agent policy -----------------------------------------------------------
HARVEST_INTERVAL_SECONDS=300
RESERVE_BPS=1000               # 10% idle withdrawal reserve
STREAM_SHARE_BPS=10000         # MVP: 100% of yield streams to savers
BUFFER_SHARE_BPS=0             # MVP: 0% to junior buffer (pure capital-protected)
MIN_CREDIT_SCORE=600           # conservative
CREDIT_ENABLED=false           # flag-gated credit module (Spec §2)

# --- Servers ----------------------------------------------------------------
AGENT_PORT=8787                # /status, /activity
INSTITUTION_PORT=8788          # x402-priced demo "institution agent" endpoint

# --- Web (Next.js, public) --------------------------------------------------
NEXT_PUBLIC_CHAIN=sepolia      # celo | sepolia | alfajores
NEXT_PUBLIC_SELF_SCOPE_SEED=kazi          # must match SELF_SCOPE_SEED
NEXT_PUBLIC_SELF_ENDPOINT=https://kazi-agent.vercel.app/api/self-verify  # must match SELF_ENDPOINT
NEXT_PUBLIC_AGENT_ADDRESS=0x321E43713F9242B4642E61B3D17edE5b540c2747  # shown on the ERC-8004 card

# --- Web server-only (Vercel) -----------------------------------------------
# The agent's funded key, used by /api/tick to allocate + harvest on the
# deployed app. Server-side only — NEVER prefix with NEXT_PUBLIC.
KAZI_AGENT_KEY=
